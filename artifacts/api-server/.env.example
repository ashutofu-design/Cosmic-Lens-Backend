# ─── Server ───────────────────────────────────────────────────────────────
PORT=8080

# Admin panel API auth (artifacts/admin-web sends X-Admin-Token)
# Production / public VPS: ADMIN_NO_AUTH=0 and set ADMIN_SECRET (generate: python -c "import secrets; print(secrets.token_hex(32))")
ADMIN_NO_AUTH=0
ADMIN_SECRET=
# PROD=1 → use gunicorn (production WSGI). Default = Flask dev server.
PROD=0

# ─── Database ─────────────────────────────────────────────────────────────
# Postgres connection string. Local example:
#   DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cosmiclens
DATABASE_URL=

# ─── Sessions ─────────────────────────────────────────────────────────────
# Generate via: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# ─── Redis (Face Reading sessions + caches) ───────────────────────────────
# docker compose -f docker-compose.yml up -d redis
REDIS_URL=redis://localhost:6379/0
FACE_REDIS_ENABLED=1
FACE_REDIS_PREFIX=face
FACE_SESSION_TTL=86400
FACE_EXTRACT_IMG_TTL=7200
FACE_ANALYSIS_TTL=86400
FACE_NARRATION_TTL=2592000
FACE_PDF_META_TTL=2592000
FACE_DEDUP_TTL=7776000
FACE_USER_DAILY_CAP_USD=2.00

# ─── Face Reading AI (12-block two-pass) ───────────────────────────────────
FACE_REPORT_LAYOUT=12_v1
FACE_AI_TWO_PASS=1
FACE_READING_AI_NARRATOR=1
FACE_READING_AI_MODE=selective
FACE_READING_PASS_A_MODEL=gpt-4.1-mini
FACE_READING_AI_MODEL=gpt-4o

# ─── Face PDF async (Celery) ─────────────────────────────────────────────────
FACE_PDF_ASYNC=1
CELERY_ENABLED=1
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_FACE_PDF_QUEUE=face_pdf
FACE_PDF_WORKER_CONCURRENCY=2
FACE_PDF_MAX_RETRIES=3
FACE_PDF_POLL_MS=800
CELERY_PING_TIMEOUT=1.5
FACE_PDF_WAIT_TIMEOUT=120
FACE_NARRATION_VERSION=face-v8-artifact
FACE_PDF_RENDER_VERSION=pdf-12block-v1
FACE_EMERGENCY_GLOBAL_CAP_USD=15
FACE_TIER_STANDARD_DAILY_USD=2.00
FACE_TIER_STANDARD_REPORT_USD=0.35
FACE_TIER_PRO_DAILY_USD=5.00
FACE_TIER_PRO_REPORT_USD=0.60

# ─── OpenAI (Cosmic Intelligence) ─────────────────────────────────────────
OPENAI_API_KEY=
# Simple Ask (default ON): D1+D9 packet, AI answers by question — no topic-lock.
# ASK_SIMPLE_MODE=1
# NARRATIVE_MODE=0
# PHASE50_MINIMAL_PROMPT=1
# PHASE51_BARE_PROMPT=1
# Testing: unlimited questions + lowest token use
# ASK_QUOTA_BYPASS=1
# ASK_SKIP_CLASSIFIER=1
# LAYER3_LLM=0
# ASK_MAX_OUTPUT_TOKENS=90
# ASK_MAX_OUTPUT_TOKENS_EXPLAIN=160

# ─── Firebase (server-side admin SDK) ─────────────────────────────────────
# Get JSON from: Firebase Console → Project Settings → Service Accounts → Generate new key
# Paste the entire JSON as a single-line string.
FIREBASE_SERVICE_ACCOUNT_JSON=

# ─── MSG91 (OTP / SMS) ────────────────────────────────────────────────────
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=

# ─── Career unlock (Life Map) ─────────────────────────────────────────────
CAREER_UNLOCK_PRICE_INR=1
CAREER_PAYMENT_REQUIRED=1

# Ask: 1 = fast LLM passthrough (default). Uses DB kundli; mobile syncs before ask.
# RAW_PASSTHROUGH_MODE=0
# Set CAREER_PAYMENT_BYPASS=1 only for local dev (skips ₹1 gate)

# ─── Razorpay (Payments) ──────────────────────────────────────────────────
# Dashboard → Account & Settings → API Keys (Test mode first, then Live)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Dashboard → Account & Settings → Webhooks → create webhook, copy secret
RAZORPAY_WEBHOOK_SECRET=
