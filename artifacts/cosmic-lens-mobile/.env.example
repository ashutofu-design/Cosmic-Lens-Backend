# ─── API endpoint ───────────────────────────────────────────────────────────
# After publishing the backend (Cosmic Lens API) on Replit, paste the URL here.
# This MUST be set before running `eas build --profile production`.
EXPO_PUBLIC_API_URL=https://cosmic-lens-api.replit.app

# ─── Firebase Web SDK config ───────────────────────────────────────────────
# Only needed if testing on web preview. Android production build uses
# google-services.json instead (does not need these).
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=cosmic-lens-62cc2.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=cosmic-lens-62cc2
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=759826116071
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=cosmic-lens-62cc2.firebasestorage.app
