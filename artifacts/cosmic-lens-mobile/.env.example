# ─── API endpoint ───────────────────────────────────────────────────────────
# After publishing the backend (Cosmic Lens API) on Replit/Render/Railway,
# paste the URL here. MUST be set before `eas build --profile production`.
#
# Local dev (VS Code, backend running on same machine):
#   EXPO_PUBLIC_API_URL=http://localhost:8080
#
# Production:
#   EXPO_PUBLIC_API_URL=https://cosmic-lens-api.replit.app
EXPO_PUBLIC_API_URL=http://localhost:8080

# ─── Firebase Web SDK config ───────────────────────────────────────────────
# Required for: phone auth on web preview, Google sign-in on web.
# Android production build uses google-services.json instead — these aren't needed there.
# Get values from: Firebase Console → Project Settings → Your apps → Web app config.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=cosmic-lens-62cc2.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=cosmic-lens-62cc2
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=759826116071
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=cosmic-lens-62cc2.firebasestorage.app
