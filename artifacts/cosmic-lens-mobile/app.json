{
  "expo": {
    "name": "Cosmic Lens",
    "slug": "cosmic-lens-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cosmic-lens",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1220"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cosmiclens.app"
    },
    "android": {
      "package": "com.cosmiclens.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0B1220"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-dev-client",
      [
        "expo-image-picker",
        {
          "photosPermission": "Cosmic Lens needs access to your photos so Acharya ji can analyze your room for Vastu guidance.",
          "cameraPermission": "Cosmic Lens needs camera access so you can capture room photos for instant Vastu analysis."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Cosmic Lens needs camera access so you can capture live room photos with the compass for accurate Vastu direction analysis.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Cosmic Lens needs location to provide a calibrated compass heading (matching the iOS Compass app) so room directions are accurate.",
          "locationWhenInUsePermission": "Cosmic Lens needs location to provide a calibrated compass heading (matching the iOS Compass app) so room directions are accurate."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "forceStaticLinking": ["RNFBApp", "RNFBAuth"]
          },
          "android": {
            "minSdkVersion": 24,
            "usesCleartextTraffic": true
          }
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/auth"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "owner": "cosmiclens",
    "extra": {
      "eas": {
        "projectId": "781866fe-35d7-4023-8b96-793f099eb824"
      }
    }
  }
}
