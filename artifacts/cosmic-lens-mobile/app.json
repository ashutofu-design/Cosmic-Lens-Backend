{
  "expo": {
    "name": "Cosmic Lens",
    "slug": "cosmic-lens-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cosmic-lens",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1220"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cosmiclens.app"
    },
    "android": {
      "package": "com.cosmiclens.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0B1220"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-dev-client",
      [
        "expo-image-picker",
        {
          "photosPermission": "Cosmic Lens needs access to your photos so Acharya ji can analyze your room for Vastu guidance.",
          "cameraPermission": "Cosmic Lens needs camera access so you can capture room photos for instant Vastu analysis."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Cosmic Lens needs camera access so you can capture live room photos with the compass for accurate Vastu direction analysis.",
          "recordAudioAndroid": false
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "expo-build-properties",
        {
          "ios": { "useFrameworks": "static" }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "1d64e5c6-e079-4d42-909c-de8484fe015d"
      }
    },
    "runtimeVersion": { "policy": "sdkVersion" },
    "owner": "satyayatra"
  }
}
